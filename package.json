    "@types/pdf-parse": "^1.1.5",
    "@types/socket.io": "^3.0.2",
    "@types/websocket": "^1.0.5",
    "@u4/opencv4nodejs": "^7.1.2",
    "adm-zip": "^0.5.16",
    "armonia": "../armonia",
    "auth0": "^4.0.1",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
