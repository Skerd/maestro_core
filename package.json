    "concurrently": "^5.3.0",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "cron": "^3.1.7",
    "cross-fetch": "^3.0.6",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "currency-codes": "^2.2.0",
    "currency-symbol-map": "^5.1.0",
