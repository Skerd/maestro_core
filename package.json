{
  "name": "arepggio_maestror",
  "version": "1.0.0",
  "description": "Arpeggio-Maestro, the server that powers all",
  "author": "Skerd Xhafa",
  "license": "Private project, to be published soon",
  "keywords": [
    ""
  ],
  "main": "",
  "opencv4nodejs": {
    "disableAutoBuild": true
  },
  "scripts": {
    "clean:js": "find . -name '*.js' ! -path '*/node_modules/*' -delete",
    "build": "tsc --skipLibCheck",
    "fetch:opencv-js": "mkdir -p vendor && curl -fsSL 'https://docs.opencv.org/4.10.0/opencv.js' -o vendor/opencv.js",
    "rebuild:opencv4nodejs": "sh scripts/rebuild-opencv4nodejs.sh",
    "install:native": "sh scripts/npm-install-with-native.sh",
    "clean": "find . -name '*.js' ! -path '*/node_modules/*' -delete",
    "start:api": "node scripts/run.js api",
    "start:websocket": "node scripts/run.js websocket",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:pdf-extraction": "ts-node -r tsconfig-paths/register tests/pdfExtractionTest.ts",
    "test:floor-opencv-runF": "ts-node --transpile-only modules/propertyManagement/utilities/edifice/floorAndUnitsGenerator/_test/runF.ts",
    "seed:edifice-demo": "ts-node --transpile-only -r tsconfig-paths/register scripts/seed-edifice-demo.ts",
    "migrate:floor-level-numbers": "ts-node --transpile-only -r tsconfig-paths/register scripts/migrations/updateFloorLevelNumberToNumber.ts",
    "migrate:cleanup-orphan-media": "ts-node --transpile-only -r tsconfig-paths/register scripts/migrations/cleanupOrphanMediaAndGridFs.ts",
    "api:development": "export NODE_ENV=development && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/apiServer.ts",
    "kafka:development": "export NODE_ENV=development && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/kafkaServer.ts",
    "websocket:development": "export NODE_ENV=development && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/webSocketServer.ts",
    "cron:development": "export NODE_ENV=development && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/cronServer.ts",
    "assistant:development": "export NODE_ENV=development && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/assistantServer.ts",
    "api": "export NODE_ENV=production && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/apiServer.ts",
    "kafka": "export NODE_ENV=production && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/kafkaServer.ts",
    "websocket": "export NODE_ENV=production && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/webSocketServer.ts",
    "cron": "export NODE_ENV=production && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/cronServer.ts",
    "assistant": "export NODE_ENV=production && ts-node-dev --transpile-only -r tsconfig-paths/register --respawn --watch ../armonia/src xServers/assistantServer.ts"
  },
  "dependencies": {
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@telegraf/types": "^7.1.0",
    "@types/auth0": "^3.3.6",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^8.5.9",
    "@types/mongoose": "^5.11.97",
