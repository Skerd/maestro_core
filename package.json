    "multer": "^2.0.2",
    "music-metadata": "^11.10.2",
    "net": "^1.0.2",
    "node-cron": "^3.0.3",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.5",
    "object-sizeof": "^1.6.3",
    "odoo-xmlrpc": "^1.0.8",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.2.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.3",
    "redis": "^4.7.0",
    "request": "^2.88.2",
    "request-ip": "^3.3.0",
    "sharp": "^0.34.5",
    "simple-xml-to-json": "^1.2.3",
    "slugify": "^1.6.6",
    "socket.io": "^4.5.3",
    "speakeasy": "^2.0.0",
    "telegraf": "^4.16.3",
    "tesseract.js": "^7.0.0",
    "timezones.json": "^1.7.1",
    "tsconfig-paths": "^4.2.0",
    "typescript-telegram-bot-api": "^0.3.6",
    "ua-parser-js": "^2.0.1",
    "websocket": "^1.0.34",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.16.0",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.14",
    "@types/kafkajs": "^1.8.2",
    "@types/node": "^18.7.23",
    "@types/sinon": "^17.0.0",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "mongodb-memory-server": "^9.1.3",
    "nock": "^13.5.0",
    "nodemon": "^2.0.4",
    "npm-run-all": "^4.1.5",
    "sinon": "^17.0.1",
    "supertest": "^7.1.0",
    "svg2img": "^0.9.4",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "4.8.4",
    "vite-tsconfig-paths": "^4.3.0",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.54.0",
    "bufferutil": "^4.0.8"
  }
}
